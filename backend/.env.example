# Application
APP_NAME="Dornika Store"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://yourdomain.com
FRONTEND_URL=http://localhost:5173

# Database
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=dornika_store
DB_USERNAME=root
DB_PASSWORD=your_secure_password_here

# Sanctum
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:3000,localhost:5173,yourdomain.com
SESSION_DRIVER=sanctum
SESSION_LIFETIME=120

# SMS Default Driver
SMS_DEFAULT_DRIVER=kavenegar

# 1. Kavenegar
SMS_KAVENEGAR_API_KEY=
SMS_KAVENEGAR_SENDER=

# 2. Meli Payamak
SMS_MELI_PAYAMAK_API_KEY=
SMS_MELI_PAYAMAK_USERNAME=
SMS_MELI_PAYAMAK_PASSWORD=

# 3. Sms.ir
SMS_SMSIR_API_KEY=
SMS_SMSIR_SECRET=
SMS_SMSIR_SENDER=

# 4. Faraz Sms
SMS_FARAZSMS_API_KEY=
SMS_FARAZSMS_SENDER=

# 5. Magfa
SMS_MAGFA_USERNAME=
SMS_MAGFA_PASSWORD=
SMS_MAGFA_SENDER=

# 6. Ghasedak
SMS_GHASEDAK_API_KEY=
SMS_GHASEDAK_SENDER=

# 7. IPPanel
SMS_IPPANEL_API_KEY=
SMS_IPPANEL_SENDER=

# 8. Payam Resan
SMS_PAYAMRESAN_API_KEY=
SMS_PAYAMRESAN_SENDER=

# 9. SmsBox
SMS_SMSBOX_API_KEY=
SMS_SMSBOX_SENDER=

# 10. Navid Sms
SMS_NAVIDSMS_API_KEY=
SMS_NAVIDSMS_SENDER=

# 11. Hooshmand Sms
SMS_HOOSHMANDSMS_API_KEY=
SMS_HOOSHMANDSMS_SENDER=

# 12. Arya Payamak
SMS_ARYAPAYAMAK_API_KEY=
SMS_ARYAPAYAMAK_SENDER=

# 13. Rayan Bit
SMS_RAYANBIT_API_KEY=
SMS_RAYANBIT_SENDER=

# Email (SMTP)
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password_here
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@yourdomain.com
MAIL_FROM_NAME="${APP_NAME}"

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=${APP_URL}/api/auth/google/callback

# Primary Admin (Change this!)
PRIMARY_ADMIN_EMAIL=admin@dornika.com
PRIMARY_ADMIN_PHONE=09123456789
PRIMARY_ADMIN_PASSWORD=ChangeMeNow123!

# Queue (Redis)
QUEUE_CONNECTION=redis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Cache
CACHE_DRIVER=redis
SESSION_DRIVER=redis

# CORS (for React Frontend)
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://yourdomain.com
